---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Savec Ingenieria | Diseño y Construcción en Honduras">
	<div class="flex flex-col md:flex-row h-screen pt-20">
		<!-- pt-20 accounts for the fixed header (h-20) -->
		<!-- Proyectos Ejecutados -->
		<a
			href="/proyectos/ejecutados"
			class="relative flex-1 md:h-full h-[50vh] overflow-hidden group"
		>
			<div
				class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105"
				style="background-image: url('/hero/hero-2.jpg');"
			>
			</div>
			<div
				class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors duration-500"
			>
			</div>
			<div
				class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center"
			>
				<h2
					class="text-3xl md:text-5xl font-bold text-white uppercase tracking-wider mb-4"
				>
					Proyectos<br />Ejecutados
				</h2>
				<span
					class="text-white/80 text-sm uppercase tracking-widest flex items-center gap-2 group-hover:text-white transition-colors"
				>
					Explorar <svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="transform group-hover:translate-x-1 transition-transform"
						><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
						></path></svg
					>
				</span>
			</div>
		</a>

		<!-- Proyectos en Ejecución -->
		<a
			href="/proyectos/en-ejecucion"
			class="relative flex-1 md:h-full h-[50vh] overflow-hidden group"
		>
			<div
				class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105"
				style="background-image: url('/hero/monaco-hero-1.jpeg');"
			>
			</div>
			<div
				class="absolute inset-0 bg-black/60 group-hover:bg-black/50 transition-colors duration-500"
			>
			</div>
			<div
				class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center"
			>
				<h2
					class="text-3xl md:text-5xl font-bold text-white uppercase tracking-wider mb-4 border-l-4 md:border-t-4 md:border-l-0 border-transparent pl-4 md:pl-0 md:pt-4"
				>
					Proyectos en<br />Ejecución
				</h2>
				<span
					class="text-white/80 text-sm uppercase tracking-widest flex items-center gap-2 group-hover:text-white transition-colors"
				>
					Explorar <svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="transform group-hover:translate-x-1 transition-transform"
						><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
						></path></svg
					>
				</span>
			</div>
		</a>
	</div>
</Layout>
