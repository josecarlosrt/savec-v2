---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto | Savec">
    <div class="mt-20 pt-20 md:pt-32 pb-24 bg-white relative">
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <!-- Header Section -->
            <div class="text-center mb-20 md:mb-28">
                <h1
                    class="text-5xl md:text-6xl font-bold tracking-tight text-gray-900 mb-20 md:mb-28"
                >
                    Contacto
                </h1>

                <!-- Contact Info Grid -->
                <div
                    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 gap-12 md:gap-8 max-w-5xl mx-auto"
                >
                    <!-- Location -->
                    <div class="flex flex-col items-center text-center">
                        <div
                            class="mb-6 flex justify-center items-center text-[#ff1a3c]"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="36"
                                height="36"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                                ></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                        </div>
                        <h3
                            class="text-xs font-bold tracking-widest text-gray-900 uppercase mb-4"
                        >
                            Honduras
                        </h3>
                        <p class="text-gray-600 mb-1">San Pedro Sula,</p>
                        <p class="text-gray-600">Cortes</p>
                    </div>

                    <!-- Email -->
                    <div
                        class="flex flex-col items-center text-center sm:col-span-2 md:col-span-1"
                    >
                        <div
                            class="mb-6 flex justify-center items-center text-[#ff1a3c]"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="36"
                                height="36"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect>
                                <path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-xs font-bold tracking-widest text-gray-900 uppercase mb-4"
                        >
                            E-mail
                        </h3>
                        <a
                            href="mailto:info@savecingenieria.com"
                            class="text-gray-600 hover:text-black transition-colors"
                            >info@savecingenieria.com</a
                        >
                    </div>
                </div>
            </div>

            <!-- Form Section -->
            <div class="max-w-4xl mx-auto mt-20 md:mt-32">
                <div class="text-center mb-12">
                    <p class="text-gray-600 mb-2">
                        ¡Complete el formulario y nos comunicaremos pronto!
                    </p>
                    <h2 class="text-3xl font-bold text-gray-900 tracking-tight">
                        Como te podemos ayudar?
                    </h2>
                </div>

                <form class="mt-12" data-netlify="true">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Left column -->
                        <div class="flex flex-col gap-6">
                            <input
                                type="text"
                                name="nombre"
                                id="nombre"
                                placeholder="Tu nombre"
                                class="w-full px-5 py-4 border border-gray-200 text-sm placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 focus:outline-none transition-colors"
                                required
                            />
                            <input
                                type="email"
                                name="correo"
                                id="correo"
                                placeholder="Correo"
                                class="w-full px-5 py-4 border border-gray-200 text-sm placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 focus:outline-none transition-colors"
                                required
                            />
                            <input
                                type="tel"
                                name="telefono"
                                id="telefono"
                                placeholder="Tu telefono"
                                class="w-full px-5 py-4 border border-gray-200 text-sm placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 focus:outline-none transition-colors"
                            />
                        </div>

                        <!-- Right column -->
                        <div class="h-full">
                            <textarea
                                name="mensaje"
                                id="mensaje"
                                placeholder="Tu mensaje"
                                class="w-full h-full min-h-[160px] md:min-h-full px-5 py-4 border border-gray-200 text-sm placeholder:text-gray-400 focus:border-gray-900 focus:ring-0 focus:outline-none transition-colors resize-none"
                                required></textarea>
                        </div>
                    </div>

                    <div
                        class="flex flex-col md:flex-row justify-between items-start md:items-center mt-8 gap-6"
                    >
                        <label
                            class="flex items-start gap-4 cursor-pointer max-w-xl group"
                        >
                            <input
                                type="checkbox"
                                name="terms"
                                id="terms"
                                required
                                class="mt-1 w-4 h-4 text-black border-gray-300 rounded focus:ring-black shrink-0"
                            />
                            <span
                                class="text-xs text-gray-500 leading-relaxed font-medium group-hover:text-gray-700 transition-colors"
                            >
                                Acepto los términos y condiciones y entiendo que
                                mis datos se conservarán de forma segura de
                                acuerdo con las <a
                                    href="#"
                                    class="font-bold border-b border-gray-400 hover:border-gray-900 transition-colors"
                                    >políticas de privacidad</a
                                >.
                            </span>
                        </label>

                        <button
                            type="submit"
                            class="bg-black text-white px-8 py-4 text-xs font-bold tracking-widest uppercase hover:bg-gray-800 transition-colors shrink-0 outline-none"
                        >
                            Enviar Mensaje
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</Layout>
