---

<section class="flex flex-col min-h-[50vh] w-full border-t border-neutral-800">
    <!-- Text and CTA -->
    <div
        class="flex-1 bg-black text-white flex flex-col items-center justify-center p-12 lg:p-24 text-center"
    >
        <div class="max-w-3xl flex flex-col items-center">
            <span
                class="text-gray-400 text-sm font-bold tracking-[0.2em] uppercase mb-6 block"
            >
                Contrataciones
            </span>
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tight mb-8 leading-tight"
            >
                ¿Quieres empezar tu proyecto de construcción con nosotros?
            </h2>
            <p class="text-gray-400 text-lg md:text-xl mb-12 max-w-2xl">
                ¡No lo dudes más, contáctanos! Nuestro equipo de expertos está
                listo para hacer realidad tu visión.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center justify-center bg-white text-gray-900 font-bold uppercase tracking-widest px-8 py-5 hover:bg-gray-200 transition-colors w-full sm:w-auto text-sm group"
            >
                Contacto <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    class="ml-3 transform group-hover:translate-x-2 transition-transform"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </div>
    </div>
</section>
