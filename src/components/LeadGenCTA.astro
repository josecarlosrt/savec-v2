---

---

<section
    class="flex flex-col md:flex-row min-h-[70vh] w-full border-t border-gray-800"
>
    <!-- Left Side: Text and CTA -->
    <div
        class="flex-1 bg-gray-900 text-white flex flex-col justify-center p-12 lg:p-24 relative overflow-hidden group"
    >
        <div class="relative z-10 max-w-xl">
            <span
                class="text-gray-400 text-sm font-bold tracking-[0.2em] uppercase mb-6 block border-l-2 border-gray-500 pl-4"
            >
                Contrataciones
            </span>
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tight mb-8 leading-tight"
            >
                ¿Quieres empezar tu proyecto de construcción con nosotros?
            </h2>
            <p class="text-gray-400 text-lg md:text-xl mb-12 max-w-md">
                ¡No lo dudes más, contáctanos! Nuestro equipo de expertos está
                listo para hacer realidad tu visión.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center justify-center bg-white text-gray-900 font-bold uppercase tracking-widest px-8 py-5 hover:bg-gray-200 transition-colors w-full sm:w-auto text-sm group-hover:pr-10"
            >
                Contacto <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    class="ml-3 transform group-hover:translate-x-2 transition-transform"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </div>
        <!-- Decor element -->
        <div
            class="absolute bottom-0 right-0 text-[20rem] font-bold text-white/[0.02] leading-none transform translate-x-1/4 translate-y-1/4 select-none"
        >
            SV
        </div>
    </div>

    <!-- Right Side: Background Image -->
    <div
        class="flex-1 min-h-[50vh] md:min-h-full bg-gray-100 relative overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-cover bg-center transition-transform duration-[10000ms] ease-linear hover:scale-110"
            style={`background-image: url('https://images.unsplash.com/photo-1541888081622-1ef024d27129?q=80&w=2070&auto=format&fit=crop');`}
        >
        </div>
    </div>
</section>
